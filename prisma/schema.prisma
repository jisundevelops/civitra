generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  nid       String?
  role      String   @default("citizen") // citizen, police, admin
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicles          Vehicle[]
  issuedViolations  Violation[] @relation("OfficerViolations")
  payments          Payment[]
}

model Vehicle {
  id                 String   @id @default(cuid())
  registrationNumber String   @unique
  ownerId            String?
  vehicleType        String?
  createdAt          DateTime @default(now())

  owner      User?        @relation(fields: [ownerId], references: [id])
  violations Violation[]
}

model ViolationType {
  id          String   @id @default(cuid())
  name        String
  description String?
  fineAmount  Float
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  violations Violation[]
}

model Violation {
  id              String   @id @default(cuid())
  vehicleId       String
  officerId       String
  violationTypeId String
  location        String?
  dateTime        DateTime @default(now())
  fineAmount      Float
  status          String   @default("pending") // pending, paid, cancelled
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  vehicle       Vehicle       @relation(fields: [vehicleId], references: [id])
  officer       User          @relation("OfficerViolations", fields: [officerId], references: [id])
  violationType ViolationType @relation(fields: [violationTypeId], references: [id])
  payment       Payment?
}

model Payment {
  id            String   @id @default(cuid())
  violationId   String   @unique
  citizenId     String
  amount        Float
  paymentDate   DateTime @default(now())
  receiptNumber String   @unique
  status        String   @default("success") // success, failed
  createdAt     DateTime @default(now())

  violation Violation @relation(fields: [violationId], references: [id])
  citizen   User      @relation(fields: [citizenId], references: [id])
}

model OtpVerification {
  id        String   @id @default(cuid())
  email     String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())
  verified  Boolean  @default(false)
}
